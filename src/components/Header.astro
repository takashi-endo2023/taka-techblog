---
const navLinks = [
  { href: '/blog/1', label: 'Blog' },
  { href: '/portfolios', label: 'Portfolios' },
  { href: '/uses', label: 'Uses' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  // /blog/1 のリンクは /blog/* すべてでアクティブにする
  if (href === '/blog/1') return currentPath.startsWith('/blog');
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="header-inner container">
    <a href="/" class="site-logo">
      <img src="/logo.png" alt="" class="logo-img" width="72" height="50" aria-hidden="true" />
      <span class="logo-text">taka-techblog</span>
    </a>

    <nav class="site-nav" id="site-nav">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={['nav-link', { active: isActive(href) }]}
        >
          {label}
        </a>
      ))}
      <!-- 検索アイコン -->
      <a
        href="/search"
        class:list={['nav-search', { active: currentPath === '/search' }]}
        aria-label="記事を検索"
        title="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>
    </nav>

    <button
      class="menu-toggle"
      id="menu-toggle"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="site-nav"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class:list={['mobile-nav-link', { active: isActive(href) }]}
      >
        {label}
      </a>
    ))}
    <a
      href="/search"
      class:list={['mobile-nav-link', { active: currentPath === '/search' }]}
    >
      Search
    </a>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const mobileNav = document.getElementById('mobile-nav')!;

  toggle.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    mobileNav.setAttribute('aria-hidden', String(isOpen));
    toggle.classList.toggle('open', !isOpen);
    mobileNav.classList.toggle('open', !isOpen);
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!toggle.contains(e.target as Node) && !mobileNav.contains(e.target as Node)) {
      toggle.setAttribute('aria-expanded', 'false');
      mobileNav.setAttribute('aria-hidden', 'true');
      toggle.classList.remove('open');
      mobileNav.classList.remove('open');
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 17, 23, 0.88);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .site-logo:hover {
    opacity: 0.8;
  }

  /* 猫シルエットを白抜きでアイコン表示 */
  .logo-img {
    display: block;
    height: 32px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .logo-text {
    font-family: var(--font-mono);
    letter-spacing: -0.01em;
  }

  /* Desktop nav */
  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: all 0.15s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
    background: var(--color-surface);
  }

  .nav-link.active {
    color: var(--color-accent-hover);
  }

  /* 検索アイコン */
  .nav-search {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: var(--color-text-muted);
    transition: all 0.15s;
    margin-left: 0.25rem;
  }

  .nav-search:hover,
  .nav-search.active {
    color: var(--color-accent-hover);
    background: var(--color-surface);
  }

  /* Hamburger button */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    transition: background 0.15s;
  }

  .menu-toggle:hover {
    background: var(--color-surface);
  }

  .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }

  .menu-toggle.open .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-toggle.open .bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-toggle.open .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile nav panel */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 0.75rem 1.5rem 1rem;
    border-top: 1px solid var(--color-border);
    gap: 0.25rem;
  }

  .mobile-nav.open {
    display: flex;
  }

  .mobile-nav-link {
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    transition: all 0.15s;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-text);
    background: var(--color-surface);
  }

  .mobile-nav-link.active {
    color: var(--color-accent-hover);
  }

  @media (max-width: 600px) {
    .site-nav {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
  }
</style>
