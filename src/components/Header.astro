---
const navLinks = [
  { href: '/blog/1', label: 'Blog' },
  { href: '/portfolios', label: 'Portfolios' },
  { href: '/uses', label: 'Uses' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const allLinks = [...navLinks, { href: '/search', label: 'Search' }];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  if (href === '/blog/1') return currentPath.startsWith('/blog');
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="header-inner container">
    <a href="/" class="site-logo">
      <picture>
        <source srcset="/logo-small.webp" type="image/webp" />
        <img src="/logo-small.png" alt="" class="logo-img" width="93" height="64" aria-hidden="true" />
      </picture>
      <span class="logo-text">taka-techblog</span>
    </a>

    <nav class="site-nav" id="site-nav">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={['nav-link', { active: isActive(href) }]}
        >
          {label}
        </a>
      ))}
      <a
        href="/search"
        class:list={['nav-search', { active: currentPath === '/search' }]}
        aria-label="記事を検索"
        title="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>
    </nav>

    <button
      class="menu-toggle"
      id="menu-toggle"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="mobile-overlay"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</header>

<!-- ===== Full-screen overlay ===== -->
<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true">
  <nav class="ov-body">
    <p class="ov-eyebrow">// NAVIGATE</p>

    {allLinks.map(({ href, label }, i) => (
      <a
        href={href}
        class:list={['ov-link', { 'ov-link--active': isActive(href) }]}
        style={`--i:${i}`}
        tabindex="-1"
      >
        <span class="ov-num">{String(i + 1).padStart(2, '0')}</span>
        <span class="ov-label">{label}</span>
        <span class="ov-arr" aria-hidden="true">↗</span>
      </a>
    ))}

    <div class="ov-foot">
      <span class="ov-foot-tag">// FOLLOW</span>
      <a
        href="https://x.com/_taka_tech"
        target="_blank"
        rel="noopener noreferrer"
        class="ov-foot-link"
        tabindex="-1"
      >@_taka_tech ↗</a>
    </div>
  </nav>
</div>

<!-- CSP (script-src 'self') はインラインスクリプトをブロックするため外部ファイルに切り出す -->
<script is:inline src="/scripts/menu.js"></script>

<style>
  /* ── Site header ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 17, 23, 0.88);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── Logo ── */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: opacity 0.15s;
    position: relative;
    z-index: 110; /* オーバーレイより前面 */
  }
  .site-logo:hover { opacity: 0.8; }

  .logo-img {
    display: block;
    height: 32px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .logo-text {
    font-family: var(--font-mono);
    letter-spacing: -0.01em;
  }

  /* ── Desktop nav ── */
  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.15s;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--color-text); background: var(--color-surface); }
  .nav-link.active { color: var(--color-accent-hover); }

  .nav-search {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.15s;
    margin-left: 0.25rem;
  }
  .nav-search:hover,
  .nav-search.active { color: var(--color-accent-hover); background: var(--color-surface); }

  /* ── Hamburger ── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: 1px solid transparent;
    border-radius: var(--radius);
    cursor: pointer;
    padding: 8px;
    position: relative;
    z-index: 110;
    transition: background 0.2s, border-color 0.2s;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
  .menu-toggle:hover {
    background: var(--color-surface);
    border-color: var(--color-border);
  }
  .menu-toggle.open {
    background: rgba(124, 106, 247, 0.1);
    border-color: rgba(124, 106, 247, 0.4);
  }

  .bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-text);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.2s;
  }
  .menu-toggle.open .bar:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle.open .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .menu-toggle.open .bar:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Overlay ── */
  /*
   * cursor:pointer を付けることで iOS Safari がオーバーレイ背景を
   * "タップ可能な要素" として認識し、touchend → click を発火するようになる。
   */
  .mobile-overlay { cursor: pointer; }
  /* 操作要素はデフォルトカーソルに戻す */
  .ov-link, .ov-foot-link, .ov-body { cursor: default; }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    overflow-y: auto;
    /* 微細なパープルグリッド + 暗い背景 */
    background:
      linear-gradient(rgba(124, 106, 247, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124, 106, 247, 0.045) 1px, transparent 1px),
      rgba(10, 11, 16, 0.97);
    background-size: 44px 44px, 44px 44px, auto;
    backdrop-filter: blur(20px) saturate(0.5);
    -webkit-backdrop-filter: blur(20px) saturate(0.5);

    /* CSS transitions はクラス変更後の "新しいスタイル" の transition を使う。
     * → .open を外す（閉じる）時：base のこの transition が使われる。
     *   visibility は opacity のフェードアウトが終わってから hidden にしたいので delay = 0.3s。 */
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0s 0.3s;
  }

  /* → .open を付ける（開く）時：この transition が使われる。
   *   visibility は即座に visible にしたいので delay なし。 */
  .mobile-overlay.open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s ease, visibility 0s;
  }

  /* デスクトップでは完全に非表示（安全策）*/
  @media (min-width: 601px) {
    .mobile-overlay { display: none; }
  }

  /* ── Overlay body ── */
  .ov-body {
    min-height: 100%;
    padding: calc(var(--header-height) + 2.75rem) 2.5rem 4rem;
    display: flex;
    flex-direction: column;
  }

  /* ── Eyebrow ── */
  .ov-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(-6px);
    /* 「開く」時に使用（base 側に delay） */
    transition: opacity 0.25s 0.08s, transform 0.25s 0.08s;
  }
  .mobile-overlay.open .ov-eyebrow {
    opacity: 0.5;
    transform: translateY(0);
    /* 「閉じる」時に使用（delay なし） */
    transition: opacity 0.15s, transform 0.15s;
  }

  /* ── Nav links ── */
  @keyframes olIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .ov-link {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(42, 45, 58, 0.5);
    text-decoration: none;
    color: var(--color-text);
    opacity: 0;
    /* 閉じる時のフェードアウト（animation が外れた後に transition が担う）*/
    transition: opacity 0.15s, color 0.15s;
  }
  .mobile-overlay.open .ov-link {
    animation: olIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.1s + var(--i, 0) * 0.065s);
  }

  .ov-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    line-height: 1;
    color: var(--color-accent);
    opacity: 0.45;
    min-width: 1.8rem;
    user-select: none;
    transition: opacity 0.15s;
  }

  .ov-label {
    font-size: 1.85rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    flex: 1;
    transition: color 0.15s, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ov-arr {
    font-size: 1rem;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-6px) translateY(4px);
    transition: opacity 0.2s, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Hover */
  .ov-link:hover .ov-label {
    color: var(--color-accent-hover);
    transform: translateX(6px);
  }
  .ov-link:hover .ov-arr  { opacity: 0.8; transform: translateX(0) translateY(0); }
  .ov-link:hover .ov-num  { opacity: 1; }

  /* Active（現在ページ）*/
  .ov-link--active .ov-label { color: var(--color-accent); }
  .ov-link--active .ov-num   { opacity: 1; }
  .ov-link--active .ov-arr   { opacity: 0.45; transform: translateX(0) translateY(0); }

  /* ── Footer ── */
  .ov-foot {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    opacity: 0;
    transform: translateY(8px);
    /* 「開く」時に使用（base 側に delay） */
    transition: opacity 0.3s 0.55s, transform 0.3s 0.55s;
  }
  .mobile-overlay.open .ov-foot {
    opacity: 1;
    transform: translateY(0);
    /* 「閉じる」時に使用（delay なし） */
    transition: opacity 0.2s, transform 0.2s;
  }

  .ov-foot-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    opacity: 0.4;
  }

  .ov-foot-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
    display: inline-block;
  }
  .ov-foot-link:hover { color: var(--color-text); }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .site-nav    { display: none; }
    .menu-toggle { display: flex; }
  }
</style>
