---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  readingTime?: number;
}

const { title, description, pubDate, slug, tags = [], readingTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="blog-card">
  <a href={`/blog/${slug}`} class="card-link" aria-label={title}>
    <div class="card-top-line"></div>
    <div class="card-inner">
      <div class="card-meta">
        <time datetime={pubDate.toISOString()} class="card-date">{formattedDate}</time>
        {readingTime && (
          <span class="card-reading-time">{readingTime} min read</span>
        )}
        <div class="card-tags">
          {tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
      <h2 class="card-title">{title}</h2>
      <p class="card-description">{description}</p>
      <span class="card-read-more">続きを読む →</span>
    </div>
  </a>
</article>

<style>
  .blog-card {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .blog-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: var(--glow-accent);
  }

  /* Gradient top line that appears on hover */
  .card-top-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #7c6af7, #a78bfa, #60a5fa);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .blog-card:hover .card-top-line {
    opacity: 1;
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card-inner {
    padding: 1.5rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .card-date {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .card-reading-time {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.1em 0.5em;
    border-radius: 4px;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-title {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    transition: color 0.15s;
    line-height: 1.4;
  }

  .blog-card:hover .card-title {
    color: var(--color-accent-hover);
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-read-more {
    font-size: 0.85rem;
    color: var(--color-accent);
    transition: gap 0.15s;
  }
</style>
