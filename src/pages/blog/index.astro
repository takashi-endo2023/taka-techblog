---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

function getReadingTime(body: string): number {
  return Math.max(1, Math.ceil(body.length / 500));
}
---

<BaseLayout
  title="Blog | Takashi.dev"
  description="フルスタック × AI × チームビルディング。医療系スタートアップで内製化・LangChain・Claude Codeを実務導入したテックリード・係長による、現場の技術判断と組織づくりの記録。"
>
  <div class="container page-content">
    <header class="page-header animate-fade-in-up">
      <h1>Blog</h1>
      <p class="page-subtitle">フルスタック・AI・チームビルディングの現場知識を言語化した記事一覧</p>
    </header>

    {allTags.length > 0 && (
      <div class="tag-filter animate-fade-in-up delay-1" id="tag-filter">
        <button class="tag-btn active" data-tag="all">すべて</button>
        {allTags.map((tag) => (
          <button class="tag-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
    )}

    {posts.length === 0 ? (
      <p class="empty-state">記事はまだありません。</p>
    ) : (
      <div class="post-list" id="post-list">
        {posts.map((post) => (
          <div class="post-item" data-tags={post.data.tags.join(',')}>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
              readingTime={getReadingTime(post.body)}
            />
          </div>
        ))}
      </div>
    )}

    <p class="no-results" id="no-results" style="display:none">
      このタグの記事はまだありません。
    </p>
  </div>
</BaseLayout>

<script>
  const filterEl = document.getElementById('tag-filter');
  const postList = document.getElementById('post-list');
  const noResults = document.getElementById('no-results');

  if (filterEl && postList) {
    const buttons = filterEl.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const items = postList.querySelectorAll<HTMLElement>('.post-item');

    filterEl.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.tag-btn');
      if (!btn) return;

      const selected = btn.dataset.tag ?? 'all';

      buttons.forEach((b) => b.classList.toggle('active', b.dataset.tag === selected));

      let visible = 0;
      items.forEach((item) => {
        const tags = item.dataset.tags?.split(',') ?? [];
        const show = selected === 'all' || tags.includes(selected);
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (noResults) {
        noResults.style.display = visible === 0 ? '' : 'none';
      }
    });
  }
</script>

<style>
  .page-content {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  /* Tag filter */
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .tag-btn {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.3em 0.75em;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
  }

  .tag-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-hover);
    background: rgba(124, 106, 247, 0.08);
  }

  .tag-btn.active {
    background: rgba(124, 106, 247, 0.15);
    color: var(--color-accent-hover);
    border-color: rgba(124, 106, 247, 0.4);
  }

  .post-list {
    display: grid;
    gap: 1.25rem;
  }

  .empty-state,
  .no-results {
    color: var(--color-text-muted);
    text-align: center;
    padding: 4rem 0;
  }
</style>
