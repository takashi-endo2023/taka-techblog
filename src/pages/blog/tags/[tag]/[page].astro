---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BlogCard from '../../../../components/BlogCard.astro';
import Pagination from '../../../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../../../lib/readingTime';

import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const now = new Date();
  const allPosts = (await getCollection('blog')).filter((p) => p.data.pubDate <= now);

  const tagCounts = allPosts.flatMap((p) => p.data.tags).reduce<Record<string, number>>((acc, t) => {
    acc[t] = (acc[t] ?? 0) + 1;
    return acc;
  }, {});
  const topTags = Object.entries(tagCounts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 15)
    .map(([t]) => t);

  const tags = [...new Set(allPosts.flatMap((p) => p.data.tags))];

  return tags.flatMap((tag) => {
    const tagPosts = allPosts
      .filter((p) => p.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

    return paginate(tagPosts, {
      params: { tag },
      props: { tag, topTags, totalTagPosts: tagPosts.length },
      pageSize: 12,
    });
  });
};

const { tag, topTags, totalTagPosts } = Astro.props as {
  tag: string;
  topTags: string[];
  totalTagPosts: number;
};
const { page } = Astro.props as { page: Page<CollectionEntry<'blog'>> };
---

<BaseLayout
  title={page.currentPage > 1
    ? `${tag}の記事一覧 — ${page.currentPage}ページ目 | taka-techblog`
    : `${tag}の記事一覧 (${totalTagPosts}件) | taka-techblog`}
  description={`${tag}に関する技術記事・現場知見を${totalTagPosts}件掲載。医療系スタートアップのテックリードが実務から得た${tag}の知識を発信しています。`}
>
  <div class="container page-content">
    <header class="page-header animate-fade-in-up">
      <a href="/blog/1" class="back-link">← Blog 一覧へ戻る</a>
      <h1>
        <span class="tag-label">#</span>{tag}
      </h1>
      <p class="page-subtitle">{totalTagPosts} 件の記事</p>
    </header>

    <nav class="tag-nav animate-fade-in-up delay-1" aria-label="タグで絞り込む">
      <a href="/blog/1" class="tag-btn">すべて</a>
      {topTags.map((t) => (
        <a
          href={`/blog/tags/${t}/1`}
          class:list={['tag-btn', { active: t === tag }]}
        >
          {t}
        </a>
      ))}
      <a href="/blog/tags" class="tag-btn tag-btn--more">すべてのタグ →</a>
    </nav>

    <div class="post-list animate-fade-in-up delay-2">
      {page.data.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
          readingTime={getReadingTime(post.body ?? '')}
        />
      ))}
    </div>

    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      totalPosts={totalTagPosts}
      pageBaseUrl={`/blog/tags/${tag}`}
    />
  </div>
</BaseLayout>

<style>
  .page-content {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .tag-label {
    color: var(--color-accent);
    margin-right: 0.1em;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-family: var(--font-mono);
  }

  .tag-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .tag-btn {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.3em 0.75em;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
  }

  .tag-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-hover);
    background: rgba(124, 106, 247, 0.08);
  }

  .tag-btn.active {
    background: rgba(124, 106, 247, 0.15);
    color: var(--color-accent-hover);
    border-color: rgba(124, 106, 247, 0.4);
  }

  .tag-btn--more {
    color: var(--color-accent);
    border-style: dashed;
  }

  .tag-btn--more:hover {
    background: rgba(124, 106, 247, 0.08);
    border-style: solid;
  }

  .post-list {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
