---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const tags = [...new Set(allPosts.flatMap((p) => p.data.tags))];

  // 使用頻度上位15件のタグ
  const tagCounts = allPosts.flatMap((p) => p.data.tags).reduce<Record<string, number>>((acc, t) => {
    acc[t] = (acc[t] ?? 0) + 1;
    return acc;
  }, {});
  const topTags = Object.entries(tagCounts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 15)
    .map(([t]) => t);

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
      topTags,
    },
  }));
}

const { tag, posts, topTags } = Astro.props;

function getReadingTime(body: string): number {
  return Math.max(1, Math.ceil(body.length / 500));
}
---

<BaseLayout
  title={`#${tag} の記事一覧 | taka-techblog`}
  description={`タグ「${tag}」が付いた記事の一覧です。`}
>
  <div class="container page-content">
    <header class="page-header animate-fade-in-up">
      <a href="/blog/1" class="back-link">← Blog 一覧へ戻る</a>
      <h1>
        <span class="tag-label">#</span>{tag}
      </h1>
      <p class="page-subtitle">{posts.length} 件の記事</p>
    </header>

    <!-- タグナビ（上位15件 ＋ 全タグリンク） -->
    <nav class="tag-nav animate-fade-in-up delay-1" aria-label="タグで絞り込む">
      <a href="/blog/1" class="tag-btn">すべて</a>
      {topTags.map((t) => (
        <a
          href={`/blog/tags/${t}`}
          class:list={['tag-btn', { active: t === tag }]}
        >
          {t}
        </a>
      ))}
      <a href="/blog/tags" class="tag-btn tag-btn--more">すべてのタグ →</a>
    </nav>

    {posts.length === 0 ? (
      <p class="empty-state">このタグの記事はまだありません。</p>
    ) : (
      <div class="post-list animate-fade-in-up delay-2">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
            readingTime={getReadingTime(post.body)}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-content {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .tag-label {
    color: var(--color-accent);
    margin-right: 0.1em;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-family: var(--font-mono);
  }

  /* 全タグナビ */
  .tag-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .tag-btn {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.3em 0.75em;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
  }

  .tag-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-hover);
    background: rgba(124, 106, 247, 0.08);
  }

  .tag-btn.active {
    background: rgba(124, 106, 247, 0.15);
    color: var(--color-accent-hover);
    border-color: rgba(124, 106, 247, 0.4);
  }

  .tag-btn--more {
    color: var(--color-accent);
    border-style: dashed;
  }

  .tag-btn--more:hover {
    background: rgba(124, 106, 247, 0.08);
    border-style: solid;
  }

  /* 記事グリッド */
  .post-list {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .empty-state {
    color: var(--color-text-muted);
    text-align: center;
    padding: 4rem 0;
  }
</style>
