---
import BaseLayout from '../layouts/BaseLayout.astro';

const associateId = 'takashi084-22';

interface AffiliateItem {
  name: string;
  description: string;
  asin?: string;
}

const sections: { title: string; items: AffiliateItem[] }[] = [
