    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .item-link:hover {
    color: var(--color-accent-hover);
  }

  .amazon-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
