---
import BaseLayout from '../../layouts/BaseLayout.astro';

const portfolios = [
  {
    title: 'AI付き広告計測・分析システム',
    tech: ['NestJS', 'Next.js 15', 'TypeScript', 'Tailwind CSS v4', 'Recharts', 'Gemini API', 'AWS Lambda'],
    description:
      '実務での「Google広告費×CRMデータ突合」の知見をベースに個人開発。複数媒体の広告費とCRMの参加ステータスを結合し、CRA（申込単価）・CRP（完了単価）を自動算出。集計データをGemini APIに渡し、構造化JSON（responseSchema）で改善アクションを自動出力するダッシュボード。',
    points: [
      'NestJS の Factory/Strategy パターンで媒体別CSVパーサーを実装・拡張性を確保',
      'バックエンド側でSQLライクな集計をプレ処理しGemini APIへのトークンを最小化',
      'Gemini SDK の responseSchema で返却JSONスキーマを完全固定し型安全な構造化出力を実現',
      'メモリキャッシュによるAPI呼び出し制御（無料枠RPM制限への対策）',
      '@vendia/serverless-express で NestJS を AWS Lambda 上にサーバーレス配置',
    ],
    screenshot: '/images/portfolio/ai-ads.png',
    github: 'https://github.com/takashi-endo2023/ai-ads-dashboard',
    demo: 'https://ai-ads.taka-techblog.com',
    relatedArticles: [
      { title: 'Claude Codeを設計の壁打ち相手として使う：アーキテクチャ相談の実践', slug: 'claude-code-as-design-partner' },
      { title: 'LangChain.js 2025年の現状：実務で使って感じたこと', slug: 'langchain-js-2025' },
    ],
  },
  {
    title: 'ECサイト（Rails 8 × React フロントエンド）',
    tech: ['React 19', 'TypeScript', 'Vite', 'Tailwind CSS v4', 'TanStack Query', 'Zustand', 'Zod', 'Rails 8', 'MySQL'],
    description:
      'Rails 8 API をバックエンドに持つフルスタック EC サイト。フロントエンドは React + TanStack Query で非同期状態を管理し、Zustand でカートを制御。管理者・ユーザー両面の UI を実装。',
    points: [
      'Rails 8 API Mode（devise-jwt 認証・Pundit 認可）と React の完全分離アーキテクチャ',
      'TanStack Query でサーバー状態キャッシュ・楽観的更新を実装',
      'Zustand によるカート状態のグローバル管理（セッション永続化）',
      'React Hook Form + Zod によるスキーマベースのバリデーション',
      '管理者ダッシュボード・商品管理・注文管理を含む全画面実装',
    ],
    screenshot: '/images/portfolio/ec.png',
    github: 'https://github.com/takashi-endo2023/ec',
    demo: 'https://ec.taka-techblog.com',
    relatedArticles: [
      { title: 'ReactとNext.jsの選定基準', slug: 'react-nextjs-selection' },
    ],
  },
  {
    title: 'サークルホームページ',
    tech: ['React 19', 'TypeScript', 'Vite', 'React Router v7', 'Swiper'],
    description:
      '地域の合唱サークルから依頼を受けて設計・実装・納品した実案件。ライブラリ依存を最小限に抑えながら、保守しやすいコンポーネント設計とアクセシビリティ対応を両立。',
    points: [
      'IntersectionObserver を使った useFadeIn カスタムフックを自前実装',
      'お知らせデータを型付き JSON で UI から分離し、担当者が更新しやすい構造に',
      'スキップナビゲーション実装によるキーボードアクセシビリティ対応',
      'React Router v7 による SPA ルーティング（直リンク・ブラウザバック対応）',
    ],
    screenshot: '/images/portfolio/utagoe.png',
    github: 'https://github.com/takashi-endo2023/utagoe_club',
    demo: 'https://utagoe.taka-techblog.com',
    relatedArticles: null,
  },
  {
    title: 'Game Portfolio Site',
    tech: ['Next.js', 'TypeScript', 'Three.js', '@react-three/fiber', 'GSAP', 'Framer Motion', 'Lenis'],
    description:
      'Three.js パーティクル・GSAP アニメーション・HUD デザインシステムで構築したシネマティックなポートフォリオサイト。ゲームUI/SF的な世界観をWebで表現。',
    points: [
      '@react-three/fiber + @react-three/drei でパーティクルフィールドを3D描画',
      'GSAP ScrollTrigger による高度なスクロール連動アニメーション',
      'Framer Motion + Lenis スムーススクロールで没入感のあるUXを実現',
      'HUDインスパイアのデザインシステムをTailwind CSS v4でゼロから設計',
    ],
    screenshot: '/images/portfolio/game.png',
    github: 'https://github.com/takashi-endo2023/game-site',
    demo: 'https://game.taka-techblog.com',
    relatedArticles: null,
  },
  {
    title: '年収トラッカー',
    tech: ['React', 'TypeScript', 'Vite', 'Recharts', 'SQLite', 'better-sqlite3', 'AWS S3', 'CloudFront'],
    description:
      '2015年からのキャリア全月次収入を記録・可視化するパーソナルファイナンスツール。ローカルでは SQLite に月単位で実データを保存・編集でき、デプロイ時はモックデータを表示するデモモードに自動切り替え。',
    points: [
      'Vite configureServer プラグインで SQLite REST API を dev server に直接注入（バックエンドプロセス不要）',
      'VITE_DEMO_MODE 環境変数でローカル（SQLite 実データ）とデプロイ（モック表示）を切り替え',
      '月次レコード（year+month 複合主キー）を better-sqlite3 で CRUD、フロントで年次集計に変換',
      'Recharts ComposedChart で年次集計グラフ（棒＋折れ線）を描画、年行クリックで月次明細を展開',
      'Vite manualChunks でアプリ本体・vendor・Recharts を分割しキャッシュ効率を最大化',
      'GitHub Actions OIDC で S3 sync → CloudFront 無効化まで自動デプロイ',
    ],
    screenshot: '/images/portfolio/salary.png',
    github: 'https://github.com/takashi-endo2023/salary-tracker',
    demo: 'https://salary.taka-techblog.com',
    relatedArticles: [
      { title: 'AstroとAWS CDK + CloudFrontで技術ブログを構築した話', slug: 'astro-aws-cdk-cloudfront-blog' },
      { title: 'GitHub ActionsとAWS OIDCでキーレスデプロイを実現する', slug: 'github-actions-oidc-aws' },
    ],
  },
];
---

<BaseLayout
  title="Portfolios | taka-techblog"
  description="設計意図まで語れる実績一覧。AWSインフラ設計からフロントエンド実装まで。"
>
  <div class="container page-content">
    <header class="page-header">
      <h1>Portfolios</h1>
      <p class="page-subtitle">設計意図まで語れる実績一覧</p>
    </header>

    <div class="portfolio-list">
      {portfolios.map((item) => (
        <article class="portfolio-card">
          <div class="card-screenshot">
            {item.screenshot
              ? (
                <picture>
                  <source srcset={item.screenshot.replace(/\.png$/, '.webp')} type="image/webp" />
                  <img src={item.screenshot} alt={`${item.title} スクリーンショット`} loading="lazy" />
                </picture>
              )
              : <div class="screenshot-placeholder"><span>screenshot coming soon</span></div>
            }
          </div>
          <header class="card-header">
            <h2>{item.title}</h2>
            <div class="tech-list">
              {item.tech.map((t) => <span class="tag">{t}</span>)}
            </div>
          </header>
          <p class="card-desc">{item.description}</p>
          <ul class="point-list">
            {item.points.map((point) => <li>{point}</li>)}
          </ul>
          {item.relatedArticles && item.relatedArticles.length > 0 && (
            <div class="related-articles">
              <p class="related-articles-label">関連記事</p>
              <ul class="related-articles-list">
                {item.relatedArticles.map((a) => (
                  <li>
                    <a href={`/blog/${a.slug}`} class="related-article-link">{a.title}</a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          <footer class="card-footer">
            {item.github && (
              <a href={item.github} target="_blank" rel="noopener" class="btn btn-outline">
                GitHub
              </a>
            )}
            {item.demo && (
              <a href={item.demo} target={item.demo.startsWith('http') ? '_blank' : undefined} rel="noopener" class="btn btn-primary">
                デモを見る →
              </a>
            )}
          </footer>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-content {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    color: var(--color-text-muted);
  }

  .portfolio-list {
    display: grid;
    gap: 2rem;
  }

  .portfolio-card {
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) * 1.5);
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color 0.15s;
  }

  .portfolio-card:hover {
    border-color: var(--color-accent);
  }

  /* スクリーンショット */
  .card-screenshot {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .card-screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .portfolio-card:hover .card-screenshot img {
    transform: scale(1.03);
  }

  .screenshot-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-linear-gradient(
      -45deg,
      var(--color-bg),
      var(--color-bg) 4px,
      var(--color-surface) 4px,
      var(--color-surface) 12px
    );
  }

  .screenshot-placeholder span {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    opacity: 0.5;
    letter-spacing: 0.05em;
  }

  .card-header {
    padding: 2rem 2rem 0;
    margin-bottom: 1rem;
  }

  .card-header h2 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    padding: 0 2rem;
  }

  .point-list {
    list-style: none;
    padding: 0 2rem;
    margin-bottom: 1.5rem;
    display: grid;
    gap: 0.5rem;
  }

  .point-list li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding-left: 1.2rem;
    position: relative;
  }

  .point-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .related-articles {
    padding: 0 2rem 1.25rem;
  }

  .related-articles-label {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .related-articles-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .related-article-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
    padding-left: 0.9rem;
    position: relative;
  }

  .related-article-link::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
  }

  .related-article-link:hover {
    color: var(--color-accent-hover);
  }

  .card-footer {
    display: flex;
    gap: 0.75rem;
    padding: 0 2rem 2rem;
  }
</style>
