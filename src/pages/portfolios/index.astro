---
import BaseLayout from '../../layouts/BaseLayout.astro';

const portfolios = [
  {
    title: '技術ブログ・ポートフォリオサイト',
    tech: ['Astro', 'TypeScript', 'AWS CDK', 'GitHub Actions', 'CloudFront', 'S3'],
    description:
      'WordPress + さくらサーバーから Astro SSG + AWS へ移行。IaC・OIDC認証・CloudFrontキャッシュ戦略まで一貫して実装。月額コストを約600円→250円に削減。',
    points: [
      'AWS CDK（TypeScript）で S3・CloudFront・ACM・Route 53 を IaC 管理',
      'GitHub Actions OIDC 認証（長期IAMキー不要）で自動デプロイ',
      'アセット別キャッシュ戦略（immutable / no-cache）でパフォーマンス最適化',
      'CloudFront OAC による S3 のパブリック非公開配信',
      'www・portfolio・utagoe サブドメインをワイルドカード証明書で一括管理',
    ],
    github: 'https://github.com/takashi-endo2023/taka-techblog',
    demo: 'https://taka-techblog.com',
  },
  {
    title: '歌声くらぶ 公式サイト',
    tech: ['React 19', 'TypeScript', 'Vite', 'React Router', 'Swiper'],
    description:
      '地域の合唱サークルから依頼を受けて設計・実装・納品した実案件。ライブラリ依存を最小限に抑えながら、保守しやすいコンポーネント設計とアクセシビリティ対応を両立。',
    points: [
      'IntersectionObserver を使った useFadeIn カスタムフックを自前実装',
      'お知らせデータを型付き JSON で UI から分離し、担当者が更新しやすい構造に',
      'スキップナビゲーション実装によるキーボードアクセシビリティ対応',
      'React Router v7 による SPA ルーティング（直リンク・ブラウザバック対応）',
    ],
    github: 'https://github.com/takashi-endo2023/utagoe_club',
    demo: 'https://utagoe.taka-techblog.com',
  },
  {
    title: 'IndexedDB 疑似CRUD アプリケーション',
    tech: ['TypeScript', 'IndexedDB', 'idb', 'Astro'],
    description:
      'サーバーサイドDB契約ゼロでCRUD操作を完全再現するブラウザアプリ。LocalStorageでなくIndexedDBを採用した理由を設計レベルで説明できるポートフォリオ。',
    points: [
      '非同期 API・大容量・構造化データに対応した IndexedDB を採用',
      'idb ライブラリで型安全な CRUD リポジトリを実装',
      '初期シードデータと永続化の状態管理を分離',
      'リロード後もデータが復元されるサーバーレス体験',
    ],
    github: 'https://github.com/takashi-endo2023/taka-techblog',
    demo: '/portfolio',
  },
];
---

<BaseLayout
  title="Portfolios | Taka Tech Blog"
  description="設計意図まで語れる実績一覧。AWSインフラ設計からフロントエンド実装まで。"
>
  <div class="container page-content">
    <header class="page-header">
      <h1>Portfolios</h1>
      <p class="page-subtitle">設計意図まで語れる実績一覧</p>
    </header>

    <div class="portfolio-list">
      {portfolios.map((item) => (
        <article class="portfolio-card">
          <header class="card-header">
            <h2>{item.title}</h2>
            <div class="tech-list">
              {item.tech.map((t) => <span class="tag">{t}</span>)}
            </div>
          </header>
          <p class="card-desc">{item.description}</p>
          <ul class="point-list">
            {item.points.map((point) => <li>{point}</li>)}
          </ul>
          <footer class="card-footer">
            {item.github && (
              <a href={item.github} target="_blank" rel="noopener" class="btn btn-outline">
                GitHub
              </a>
            )}
            {item.demo && (
              <a href={item.demo} target={item.demo.startsWith('http') ? '_blank' : undefined} rel="noopener" class="btn btn-primary">
                デモを見る →
              </a>
            )}
          </footer>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-content {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    color: var(--color-text-muted);
  }

  .portfolio-list {
    display: grid;
    gap: 2rem;
  }

  .portfolio-card {
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) * 1.5);
    padding: 2rem;
    background: var(--color-surface);
    transition: border-color 0.15s;
  }

  .portfolio-card:hover {
    border-color: var(--color-accent);
  }

  .card-header {
    margin-bottom: 1rem;
  }

  .card-header h2 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }

  .point-list {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
    display: grid;
    gap: 0.5rem;
  }

  .point-list li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding-left: 1.2rem;
    position: relative;
  }

  .point-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .card-footer {
    display: flex;
    gap: 0.75rem;
  }
</style>
