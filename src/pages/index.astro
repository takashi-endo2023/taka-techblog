---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

function getReadingTime(body: string): number {
  return Math.max(1, Math.ceil(body.length / 500));
}
---

<BaseLayout title="taka-techblog | フルスタック × AI × チームビルディング">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg-grid" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-badge animate-fade-in-up">
        <span class="badge-dot"></span>
        <span class="tag">Medical IT / テックリード / 転身エンジニア</span>
      </div>
      <h1 class="hero-title">
        フルスタックで作り、<br />
        AIで加速させ、<br />
        <span class="gradient-text">チームで届ける</span>
      </h1>
      <p class="hero-subtitle animate-fade-in-up delay-2">
        医療系スタートアップでシステム内製化を完遂し、<br />
        LangChain × Claude Code で AI 開発を実務に導入。<br />
        現場の技術判断と組織づくりの知見を発信します。
      </p>
      <div class="hero-actions animate-fade-in-up delay-3">
        <a href="/blog" class="btn btn-primary">記事を読む</a>
        <a href="/portfolios" class="btn btn-outline">実績を見る</a>
      </div>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="section container">
    <div class="section-header">
      <h2>最近の記事</h2>
      <a href="/blog" class="section-link">すべて見る →</a>
    </div>
    <div class="card-grid">
      {recentPosts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
          readingTime={getReadingTime(post.body ?? '')}
        />
      ))}
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="section-title-center">Tech Stack</h2>
      <div class="stack-grid">
        {[
          { name: 'TypeScript',        desc: '型安全なフルスタック開発',               icon: '⚡' },
          { name: 'React / Next.js',   desc: 'フロントエンド・SSR',                  icon: '⚛️' },
          { name: 'NestJS / Node.js',  desc: 'バックエンドAPI設計',                  icon: '🛡️' },
          { name: 'AWS',               desc: 'EC2 / S3 / RDS / Lambda の運用・監視', icon: '☁️' },
          { name: 'LangChain',         desc: '自社CRMへのAI連携実装',                icon: '🔗' },
          { name: 'Claude Code / Cursor', desc: 'AI駆動の高速開発・レビュー効率化',  icon: '🧠' },
          { name: 'Docker / GitLab',   desc: 'コンテナ・業務CI/CDパイプライン',          icon: '🐳' },
          { name: 'Astro / AWS CDK',   desc: 'このブログで初挑戦 — SSG × IaC',          icon: '🚀' },
        ].map(({ name, desc, icon }) => (
          <div class="stack-item">
            <span class="stack-icon">{icon}</span>
            <p class="stack-name">{name}</p>
            <p class="stack-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 5.5rem 0 4.5rem;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse at 65% 0%, rgba(124, 106, 247, 0.18) 0%, transparent 55%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 660px;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4);
    animation: pulse-ring 2.5s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.2;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(135deg, #7c6af7 0%, #a78bfa 50%, #60a5fa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin-bottom: 2.25rem;
    max-width: 520px;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Sections ── */
  .section {
    padding: 4rem 0;
  }

  .section-dark {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    letter-spacing: -0.01em;
  }

  .section-link {
    font-size: 0.9rem;
    color: var(--color-accent);
    transition: color 0.15s, gap 0.15s;
  }

  .section-link:hover {
    color: var(--color-accent-hover);
  }

  .card-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  /* ── Tech Stack ── */
  .section-title-center {
    font-size: 1.5rem;
    text-align: center;
    margin-bottom: 2.5rem;
    letter-spacing: -0.01em;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 1rem;
  }

  .stack-item {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .stack-item:hover {
    border-color: var(--color-accent);
    box-shadow: var(--glow-accent);
    transform: translateY(-2px);
  }

  .stack-icon {
    display: block;
    font-size: 1.4rem;
    margin-bottom: 0.6rem;
    line-height: 1;
  }

  .stack-name {
    font-weight: 600;
    font-size: 0.9rem;
    font-family: var(--font-mono);
    color: var(--color-accent-hover);
    margin-bottom: 0.25rem;
  }

  .stack-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

</style>
