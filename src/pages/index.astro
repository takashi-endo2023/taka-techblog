<BaseLayout title="taka-techblog | フルスタック × AI × チームビルディング">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg-grid" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-badge animate-fade-in-up">
        <span class="badge-dot"></span>
        <span class="tag">Medical IT / テックリード / 転身エンジニア</span>
      </div>
      <h1 class="hero-title">
        フルスタックで作り、AIで加速させ、<span class="gradient-text">チームで届ける</span>まで。
      </h1>
      <p class="hero-subtitle animate-fade-in-up delay-2">
        医療×規制産業のスタートアップでシステムを内製化し、<br />
        AI開発フローの標準化と組織づくりを推進。<br />
        現場の技術判断と試行錯誤を、そのまま言語化して発信します。
      </p>
      <div class="hero-actions animate-fade-in-up delay-3">
        <a href="/blog" class="btn btn-primary">記事を読む</a>
        <a href="/portfolios" class="btn btn-outline">実績を見る</a>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  <section class="section home-wide">
    <div class="section-header">
      <div class="featured-title-group">
        <h2>おすすめ記事</h2>
        <span class="featured-label">まずはここから</span>
      </div>
    </div>
    <div class="card-grid">
      {featuredPosts.map((post) => (
        <div class="featured-card-wrapper">
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
            readingTime={getReadingTime(post.body ?? '')}
          />
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="section home-wide">
    <div class="section-header">
      <h2>最近の記事</h2>
      <a href="/blog" class="section-link">すべて見る →</a>
    </div>
    <div class="card-grid">
      {recentPosts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
          readingTime={getReadingTime(post.body ?? '')}
        />
      ))}
    </div>
  </section>

  <!-- Category picks -->
  <section class="section home-wide">
    <div class="section-header">
      <h2>カテゴリで読む</h2>
      <a href="/blog/tags" class="section-link">タグ一覧 →</a>
    </div>
    <div class="category-grid">
      {categories.map(({ label, tag, posts }) => (
        <div class="category-card">
          <div class="category-header">
            <a href={`/blog/tags/${tag}/1`} class="category-title">{label}</a>
          </div>
          <ul class="category-posts">
            {posts.map((p) => (
              <li class="category-post-item">
                <a href={`/blog/${p.id}`} class="category-post-link">{p.data.title}</a>
                <span class="category-post-date">
                  {p.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
              </li>
            ))}
          </ul>
          <a href={`/blog/tags/${tag}/1`} class="category-more">もっと見る →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section section-dark">
    <div class="home-wide">
      <h2 class="section-title-center">Tech Stack</h2>
      <div class="stack-grid">
        {techStack.map(({ name, desc, icon }) => (
          <div class="stack-item">
            <svg class="stack-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" role="img">
              <path d={icon} />
            </svg>
            <p class="stack-name">{name}</p>
            <p class="stack-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 5.5rem 0 4.5rem;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse at 65% 0%, rgba(124, 106, 247, 0.18) 0%, transparent 55%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 660px;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4);
    animation: pulse-ring 2.5s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.2;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(135deg, #7c6af7 0%, #a78bfa 50%, #60a5fa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    margin-bottom: 2.25rem;
    max-width: 520px;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Sections ── */
  /* padding-block のみ指定（左右は .container の 1.5rem を活かす）。
     padding ショートハンドだと左右0が .container を上書きし、スマホでカードが画面端に密着する */
  .section {
    padding-block: 4rem;
  }

  /* ホーム専用の広いラッパー（記事の 860px 読み幅は変えず、トップだけ 1080px で
     カードを 3枚/4枚そろえて並べる）。左右パディングは .container と同じ 1.5rem */
  .home-wide {
    max-width: 1080px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .section-dark {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    letter-spacing: -0.01em;
  }

  .section-link {
    font-size: 0.9rem;
    color: var(--color-accent);
    transition: color 0.15s, gap 0.15s;
  }

  .section-link:hover {
    color: var(--color-accent-hover);
  }

  .card-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  /* おすすめ・最近は各3枚。640px以上で2列、980px以上で3列（3枚が1行で埋まる） */
  @media (min-width: 640px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 980px) {
    .card-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Featured Posts ── */
  .featured-title-group {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .featured-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .featured-card-wrapper :global(.card-top-line) {
    opacity: 1;
  }

  /* ── Category picks ── */
  .category-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  /* カテゴリは4つ。640px以上で2列(2×2)、980px以上で4列（4枚が1行で埋まる） */
  @media (min-width: 640px) {
    .category-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 980px) {
    .category-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .category-card {
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .category-card:hover {
    border-color: var(--color-accent);
  }

  .category-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.75rem;
  }

  .category-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-accent-hover);
    text-decoration: none;
    transition: color 0.15s;
  }

  .category-title:hover {
    color: var(--color-text);
  }

  .category-posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .category-post-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .category-post-link {
    font-size: 0.88rem;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.15s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .category-post-link:hover {
    color: var(--color-accent-hover);
  }

  .category-post-date {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .category-more {
    font-size: 0.82rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s;
    align-self: flex-start;
  }

  .category-more:hover {
    color: var(--color-accent-hover);
  }

  /* ── Tech Stack ── */
  .section-title-center {
    font-size: 1.5rem;
    text-align: center;
    margin-bottom: 2.5rem;
    letter-spacing: -0.01em;
  }

  .stack-grid {
    display: grid;
