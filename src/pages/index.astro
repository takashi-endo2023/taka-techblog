---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import featuredSlugs from '../data/featured.json';

const now = new Date();
const allPosts = (await getCollection('blog')).filter((p) => p.data.pubDate <= now);
const sorted = [...allPosts].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const recentPosts = sorted.slice(0, 3);

// おすすめ記事は src/data/featured.json で管理（content-plan.js と共有）。
// 公開済み（pubDate <= now）のものだけ表示。未来日・typo は自動的に除外される。
const featuredPosts = (featuredSlugs as string[])
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => p != null);

function getReadingTime(body: string): number {
  return Math.max(1, Math.ceil(body.length / 300));
}

const categoryDefs = [
  { label: 'AI・Claude Code',       tag: 'AI開発' },
  { label: 'テックリード・組織',     tag: 'テックリード' },
  { label: 'インフラ・DevOps',       tag: 'DevOps' },
  { label: '医療IT',                tag: '医療IT' },
] as const;

const categories = categoryDefs.map(({ label, tag }) => ({
  label,
  tag,
  posts: sorted.filter((p) => p.data.tags.includes(tag)).slice(0, 3),
}));
---

<BaseLayout title="taka-techblog | フルスタック × AI × チームビルディング">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg-grid" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-badge animate-fade-in-up">
        <span class="badge-dot"></span>
        <span class="tag">Medical IT / テックリード / 転身エンジニア</span>
      </div>
      <h1 class="hero-title">
        フルスタックで作り、<br />
        AIで加速させ、<br />
        <span class="gradient-text">チームで届ける</span>
      </h1>
      <p class="hero-subtitle animate-fade-in-up delay-2">
        医療×規制産業のスタートアップでシステムを内製化し、<br />
        AI開発フローの標準化と組織づくりを推進。<br />
        現場の技術判断と試行錯誤を、そのまま言語化して発信します。
      </p>
      <div class="hero-actions animate-fade-in-up delay-3">
        <a href="/blog" class="btn btn-primary">記事を読む</a>
        <a href="/portfolios" class="btn btn-outline">実績を見る</a>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  <section class="section container">
    <div class="section-header">
      <div class="featured-title-group">
        <h2>おすすめ記事</h2>
        <span class="featured-label">まずはここから</span>
      </div>
    </div>
    <div class="card-grid">
      {featuredPosts.map((post) => (
        <div class="featured-card-wrapper">
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
            readingTime={getReadingTime(post.body ?? '')}
          />
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="section container">
    <div class="section-header">
      <h2>最近の記事</h2>
      <a href="/blog" class="section-link">すべて見る →</a>
    </div>
    <div class="card-grid">
      {recentPosts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
          readingTime={getReadingTime(post.body ?? '')}
        />
      ))}
    </div>
  </section>

  <!-- Category picks -->
  <section class="section container">
    <div class="section-header">
      <h2>カテゴリで読む</h2>
      <a href="/blog/tags" class="section-link">タグ一覧 →</a>
    </div>
    <div class="category-grid">
      {categories.map(({ label, tag, posts }) => (
        <div class="category-card">
          <div class="category-header">
            <a href={`/blog/tags/${tag}/1`} class="category-title">{label}</a>
          </div>
          <ul class="category-posts">
            {posts.map((p) => (
              <li class="category-post-item">
                <a href={`/blog/${p.id}`} class="category-post-link">{p.data.title}</a>
                <span class="category-post-date">
                  {p.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
              </li>
            ))}
          </ul>
          <a href={`/blog/tags/${tag}/1`} class="category-more">もっと見る →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="section-title-center">Tech Stack</h2>
      <div class="stack-grid">
        {[
          { name: 'TypeScript',        desc: '型安全なフルスタック開発',               icon: '⚡' },
          { name: 'React / Next.js',   desc: 'フロントエンド・SSR',                  icon: '⚛️' },
          { name: 'NestJS / Node.js',  desc: 'バックエンドAPI設計',                  icon: '🛡️' },
          { name: 'Flutter / Dart',    desc: '介護向けモバイルアプリの引き継ぎ・保守', icon: '📱' },
          { name: 'AWS',               desc: 'EC2 / S3 / RDS / Lambda の運用・監視', icon: '☁️' },
          { name: 'LangChain',         desc: '自社CRMへのAI連携実装',                icon: '🔗' },
          { name: 'Claude Code / Cursor', desc: 'AI駆動の高速開発・レビュー効率化',  icon: '🧠' },
          { name: 'Docker / GitLab',   desc: 'コンテナ・業務CI/CDパイプライン',          icon: '🐳' },
          { name: 'Astro / AWS CDK',   desc: 'このブログで初挑戦 — SSG × IaC',          icon: '🚀' },
        ].map(({ name, desc, icon }) => (
          <div class="stack-item">
            <span class="stack-icon">{icon}</span>
            <p class="stack-name">{name}</p>
            <p class="stack-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 5.5rem 0 4.5rem;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse at 65% 0%, rgba(124, 106, 247, 0.18) 0%, transparent 55%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 660px;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4);
    animation: pulse-ring 2.5s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.2;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(135deg, #7c6af7 0%, #a78bfa 50%, #60a5fa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin-bottom: 2.25rem;
    max-width: 520px;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Sections ── */
  .section {
    padding: 4rem 0;
  }

  .section-dark {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    letter-spacing: -0.01em;
  }

  .section-link {
    font-size: 0.9rem;
    color: var(--color-accent);
    transition: color 0.15s, gap 0.15s;
  }

  .section-link:hover {
    color: var(--color-accent-hover);
  }

  .card-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  /* ── Featured Posts ── */
  .featured-title-group {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .featured-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .featured-card-wrapper :global(.card-top-line) {
    opacity: 1;
  }

  /* ── Category picks ── */
  .category-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }

  .category-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s;
  }

  .category-card:hover {
    border-color: var(--color-accent);
  }

  .category-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.75rem;
  }

  .category-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-accent-hover);
    text-decoration: none;
    transition: color 0.15s;
  }

  .category-title:hover {
    color: var(--color-text);
  }

  .category-posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .category-post-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .category-post-link {
    font-size: 0.88rem;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.15s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .category-post-link:hover {
    color: var(--color-accent-hover);
  }

  .category-post-date {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .category-more {
    font-size: 0.82rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s;
    align-self: flex-start;
  }

  .category-more:hover {
    color: var(--color-accent-hover);
  }

  /* ── Tech Stack ── */
  .section-title-center {
    font-size: 1.5rem;
    text-align: center;
    margin-bottom: 2.5rem;
    letter-spacing: -0.01em;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 1rem;
  }

  .stack-item {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .stack-item:hover {
    border-color: var(--color-accent);
    box-shadow: var(--glow-accent);
    transform: translateY(-2px);
  }

  .stack-icon {
    display: block;
    font-size: 1.4rem;
    margin-bottom: 0.6rem;
    line-height: 1;
  }

  .stack-name {
    font-weight: 600;
    font-size: 0.9rem;
    font-family: var(--font-mono);
    color: var(--color-accent-hover);
    margin-bottom: 0.25rem;
  }

  .stack-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

</style>
