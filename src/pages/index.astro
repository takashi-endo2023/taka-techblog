import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import featuredSlugs from '../data/featured.json';
import { getReadingTime } from '../lib/readingTime';

const now = new Date();
const allPosts = (await getCollection('blog')).filter((p) => p.data.pubDate <= now);
const sorted = [...allPosts].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const recentPosts = sorted.slice(0, 3);

// おすすめ記事は src/data/featured.json で管理（content-plan.js と共有）。
// 公開済み（pubDate <= now）のものだけ表示。未来日・typo は自動的に除外される。
const featuredPosts = (featuredSlugs as string[])
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => p != null);

const categoryDefs = [
  { label: 'AI・Claude Code',       tag: 'AI開発' },
  { label: 'テックリード・組織',     tag: 'テックリード' },
  { label: 'インフラ・DevOps',       tag: 'DevOps' },
  { label: '医療IT',                tag: '医療IT' },
] as const;

// カテゴリは「おすすめ」「最近」で既に出した記事、およびカテゴリ間で重複する記事を
// 表示しない（同じタイトルがトップに何度も並ぶのを防ぎ、回遊性を上げる）。
// タグ重複の多い近作AI記事が AI と テックリード の両カードに同じ並びで出る問題への対処。
const usedInCategories = new Set<string>([
  ...featuredPosts.map((p) => p.id),
  ...recentPosts.map((p) => p.id),
]);
const categories = categoryDefs.map(({ label, tag }) => {
  const posts = sorted
    .filter((p) => p.data.tags.includes(tag) && !usedInCategories.has(p.id))
    .slice(0, 3);
  posts.forEach((p) => usedInCategories.add(p.id));
  return { label, tag, posts };
});

