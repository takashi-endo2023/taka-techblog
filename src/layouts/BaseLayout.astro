---
import { ClientRouter } from 'astro:transitions';
import fontsCSS  from '../styles/fonts.css?raw';
import _globalCSS from '../styles/global.css?raw';
// @import './fonts.css' はインライン style では相対パスが解決されないため除去し、
// fonts.css の内容を直接結合する
const globalCSS = fontsCSS + '\n' + _globalCSS.replace(/@import\s+['"]\.\/fonts\.css['"]\s*;?\n?/, '');
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  pubDate?: Date;
  noindex?: boolean;   // タグ/ページネーション等の一覧ページを検索インデックスから除外する
}

const {
  title,
  description = '医療系スタートアップでシステム内製化を完遂したテックリードが、TypeScript / React / NestJS / LangChain / Claude Code の現場知識とチームビルディングを発信するブログ。',
  ogImage = '/og/default.png',
  ogType = 'website',
  pubDate,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// サイト全体の構造化データ（WebSite + 著者 Person）。E-E-A-T と検索の指名認識に効く
const siteUrl = (Astro.site?.toString() ?? 'https://www.taka-techblog.com/').replace(/\/$/, '');
const siteJsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'taka-techblog',
    url: siteUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Taka',
    url: siteUrl,
    jobTitle: 'テックリード',
    sameAs: [
      'https://x.com/_taka_tech',
      'https://github.com/takashi-endo2023',
    ],
  },
]);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f1117" />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="taka-techblog" />
    {ogType === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@_taka_tech" />
    <meta name="twitter:creator" content="@_taka_tech" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="taka-techblog RSS"
      href="/blog/rss.xml"
    />

    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <ClientRouter />

    <!-- サイト全体の構造化データ（WebSite + Person） -->
    <script type="application/ld+json" is:inline set:html={siteJsonLd} />

    <!-- グローバルCSS インライン化（追加のネットワークリクエストを排除） -->
    <Fragment set:html={`<style>${globalCSS}</style>`} />

    <slot name="head" />

    <!-- Preconnect: GA4 が使う外部オリジンへの接続を先行確立 -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />

    <!-- Web Fonts (self-hosted: チェーンなしで直接 preload) -->
    <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jetbrains-mono-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Google Search Console 所有権確認 -->
    <meta name="google-site-verification" content="5bFeh_oE3xFoZlzFmfrQsLaSNOBzvASdeKtMyNvhxks" />

    <!-- impact.com サイト所有権確認（value 属性が正・content ではない。
         astro check が value 属性を型エラーにするため set:html で生出力） -->
    <Fragment set:html={`<meta name="impact-site-verification" value="fb1cd4b2-78c8-4fe0-8ea8-9a25bbac9390" />`} />

    <!-- Google Analytics (async: レンダリングをブロックしない / inline 排除で CSP strict 対応) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-SSWBR8E9JH"></script>
    <script is:inline src="/scripts/ga.js"></script>

    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-6362820016436423" />
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6362820016436423" crossorigin="anonymous"></script>
  </head>
  <body>
    <a href="#main" class="skip-link">本文へスキップ</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <a href="#" class="back-to-top" id="back-to-top" aria-label="ページ上部へ戻る">↑</a>
  </body>
</html>

<!-- CSP (script-src 'self') はインラインスクリプトをブロックするため外部ファイルに切り出す -->
<script is:inline src="/scripts/ui.js"></script>
